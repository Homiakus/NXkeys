<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <OutputType>Library</OutputType>
    <AssemblyName>NX2512_CommandBridge</AssemblyName>
    <RootNamespace>NX2512_CommandBridge</RootNamespace>

    <PlatformTarget>x64</PlatformTarget>
    <Prefer32Bit>false</Prefer32Bit>
    <UseWindowsForms>true</UseWindowsForms>

    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <LangVersion>latest</LangVersion>

    <Deterministic>true</Deterministic>
    <DebugType>portable</DebugType>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <GenerateRuntimeConfigurationFiles>true</GenerateRuntimeConfigurationFiles>
    <CopyLocalLockFileAssemblies>false</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="NXOpen">
      <HintPath>$(NXOpenDir)\NXOpen.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="NXOpen.Utilities" Condition="Exists('$(NXOpenDir)\NXOpen.Utilities.dll')">
      <HintPath>$(NXOpenDir)\NXOpen.Utilities.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="NXOpen.UF" Condition="Exists('$(NXOpenDir)\NXOpen.UF.dll')">
      <HintPath>$(NXOpenDir)\NXOpen.UF.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="NXOpenUI">
      <HintPath>$(NXOpenDir)\NXOpenUI.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup Condition="'$(NXSigningResource)' != '' and Exists('$(NXSigningResource)')">
    <EmbeddedResource Include="$(NXSigningResource)">
      <LogicalName>NXSigningResource.res</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <Target Name="ValidateNxOpenReference" BeforeTargets="ResolveReferences">
    <Error
      Condition="'$(NXOpenDir)' == ''"
      Text="NXOpenDir is not defined. Pass -p:NXOpenDir=&quot;...\NXBIN\managed&quot;." />
    <Error
      Condition="!Exists('$(NXOpenDir)\NXOpen.dll')"
      Text="NXOpen.dll was not found in NXOpenDir=$(NXOpenDir)." />
    <Error
      Condition="!Exists('$(NXOpenDir)\NXOpenUI.dll')"
      Text="NXOpenUI.dll was not found in NXOpenDir=$(NXOpenDir)." />
  </Target>

</Project>
