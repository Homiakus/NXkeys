{
  "schema_version": 2,
  "timeouts": {
    "root_ms": 4000,
    "prefix_ms": 2500,
    "search_ms": 5000,
    "confirmation_ms": 10000,
    "result_ms": 20000,
    "module_switch_ms": 8000
  },
  "defaults": {
    "minimum_context_confidence": 60,
    "bridge_statuses": ["running"],
    "interaction_states": ["idle"],
    "on_unavailable": {
      "action": "show_reason",
      "message": "Команда недоступна в текущем контексте NX"
    }
  },
  "adaptive_module": {
    "enabled": true,
    "scope": "active_module",
    "auto_prefix": true,
    "fallback_module": "modeling",
    "search_scope": "active_module"
  },
  "commands": {
    "MX": {
      "guards": {
        "modules": ["modeling"],
        "require_work_part": true,
        "minimum_context_confidence": 60,
        "selection": { "minimum": 1, "types_any": ["Edge"] }
      },
      "on_unavailable": { "action": "show_reason", "message": "Выберите одно или несколько рёбер" }
    },
    "MZ": {
      "guards": {
        "modules": ["modeling"],
        "require_work_part": true,
        "selection": { "minimum": 1, "types_any": ["Edge"] }
      },
      "on_unavailable": { "action": "show_reason", "message": "Выберите рёбра для построения фаски" }
    },
    "SW": {
      "guards": { "modules": ["sketch"], "require_work_part": true },
      "on_unavailable": { "action": "show_reason", "message": "Команда Line доступна в активном эскизе" }
    },
    "DW": {
      "guards": { "modules": ["drafting"], "require_work_part": true },
      "on_unavailable": { "action": "show_reason", "message": "Команда Base View доступна в Drafting" }
    },
    "AX": {
      "guards": {
        "modules": ["assembly"],
        "require_work_part": true,
        "selection": { "minimum": 1, "types_any": ["Component"] }
      },
      "confirmation": "required",
      "on_unavailable": { "action": "show_reason", "message": "Выберите компонент для замены" }
    },
    "AZ": {
      "guards": {
        "modules": ["assembly"],
        "require_work_part": true,
        "selection": { "minimum": 1, "types_any": ["Component"] }
      },
      "confirmation": "required",
      "on_unavailable": { "action": "show_reason", "message": "Выберите компонент для удаления" }
    },
    "CX": { "guards": { "modules": ["manufacturing"], "require_work_part": true, "selection": { "minimum": 1 } }, "confirmation": "required" },
    "CZ": { "guards": { "modules": ["manufacturing"], "require_work_part": true, "selection": { "minimum": 1 } }, "confirmation": "required" },
    "XX": { "guards": { "modules": ["simulation"], "require_work_part": true, "selection": { "minimum": 1 } }, "confirmation": "required" },
    "XZ": { "guards": { "modules": ["simulation"], "require_work_part": true, "selection": { "minimum": 1 } }, "confirmation": "required" },
    "GX": { "guards": { "modules": ["routing"], "require_work_part": true, "selection": { "minimum": 1 } }, "confirmation": "required" },
    "GZ": { "guards": { "modules": ["routing"], "require_work_part": true, "selection": { "minimum": 1 } }, "confirmation": "required" },
    "RX": { "guards": { "modules": ["reuse"], "require_work_part": true, "selection": { "minimum": 1 } }, "confirmation": "required" }
  }
}
