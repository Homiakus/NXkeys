{
  "schema_version": 1,
  "timeouts": {
    "root_ms": 4000,
    "prefix_ms": 2500,
    "search_ms": 5000,
    "confirmation_ms": 10000,
    "result_ms": 20000,
    "module_switch_ms": 8000
  },
  "defaults": {
    "minimum_context_confidence": 60,
    "bridge_statuses": ["running"],
    "interaction_states": ["idle"],
    "on_unavailable": {
      "action": "show_reason",
      "message": "Команда недоступна в текущем контексте NX"
    }
  },
  "commands": {
    "MB": {
      "guards": {
        "modules": ["modeling"],
        "require_work_part": true,
        "minimum_context_confidence": 60,
        "selection": {
          "minimum": 1,
          "types_any": ["Edge"]
        }
      },
      "on_unavailable": {
        "action": "show_reason",
        "message": "Выберите одно или несколько рёбер"
      }
    },
    "MC": {
      "guards": {
        "modules": ["modeling"],
        "require_work_part": true,
        "selection": {
          "minimum": 1,
          "types_any": ["Edge"]
        }
      },
      "on_unavailable": {
        "action": "show_reason",
        "message": "Выберите рёбра для построения фаски"
      }
    },
    "SL": {
      "guards": {
        "modules": ["sketch"],
        "require_work_part": true
      },
      "on_unavailable": {
        "action": "switch_module",
        "target_module": "sketch",
        "retry_once": true,
        "message": "Переход в Sketch перед запуском команды"
      }
    },
    "DB": {
      "guards": {
        "modules": ["drafting"],
        "require_work_part": true
      },
      "on_unavailable": {
        "action": "switch_module",
        "target_module": "drafting",
        "retry_once": true,
        "message": "Переход в Drafting перед созданием базового вида"
      }
    },
    "AX": {
      "guards": {
        "modules": ["assembly"],
        "require_work_part": true,
        "selection": {
          "minimum": 1,
          "types_any": ["Component"]
        }
      },
      "confirmation": "required",
      "on_unavailable": {
        "action": "show_reason",
        "message": "Выберите компонент для удаления"
      }
    }
  }
}
